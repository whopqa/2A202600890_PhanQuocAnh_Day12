# Copy to .env.local and fill in real values.
# NEVER commit .env.local to Git.

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── App ────────────────────────────────────────────────────────
APP_NAME=Legal RAG Multiagent System
APP_VERSION=1.0.0

# ── LLM (OpenRouter) ───────────────────────────────────────────
# Set OPENROUTER_API_KEY to enable live LLM calls
# Leave blank to use offline fallback mode
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_MAX_TOKENS=1000

# Disable LLM entirely for offline testing (set to "true")
DAY08_DISABLE_LLM=false

# ── Security (change in production!) ───────────────────────────
AGENT_API_KEY=dev-key-change-me-in-production
JWT_SECRET=dev-jwt-secret-change-in-production

# ── Rate & Budget ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60
MONTHLY_BUDGET_USD=10.0

# ── Storage (Redis) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
MAX_HISTORY_MESSAGES=20
HISTORY_TTL_SECONDS=604800

# ── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:11014

# ── Day08 Multiagent ports ─────────────────────────────────────
DAY08_REGISTRY_PORT=11000
DAY08_CUSTOMER_AGENT_PORT=11010
DAY08_ORCHESTRATOR_AGENT_PORT=11011
DAY08_LEGAL_RAG_AGENT_PORT=11012
DAY08_NEWS_RAG_AGENT_PORT=11013
DAY08_UI_PORT=11014

# ── Day08 service URLs (for inter-agent communication) ─────────
DAY08_REGISTRY_URL=http://127.0.0.1:11000
DAY08_CUSTOMER_AGENT_URL=http://127.0.0.1:11010
DAY08_ORCHESTRATOR_AGENT_URL=http://127.0.0.1:11011
DAY08_LEGAL_RAG_AGENT_URL=http://127.0.0.1:11012
DAY08_NEWS_RAG_AGENT_URL=http://127.0.0.1:11013
